{
  "title": "Django Backend Metrics",
  "uid": "django-metrics-dashboard",
  "version": 2,
  "panels": [
    {
      "type": "timeseries",
      "title": "Backend Service Status",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"django\"}",
          "refId": "A",
          "legendFormat": "backend"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests by Method",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_method_total{job=\"django\"}[5m])) by (method)",
          "refId": "A",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket{job=\"django\"}[5m])) by (le, view, method)) * 1000",
          "refId": "A",
          "legendFormat": "{{view}} {{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests by View",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_view_transport_method_total{job=\"django\"}[5m])) by (view)",
          "refId": "A",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Responses by Status",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{job=\"django\"}[5m])) by (status)",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Exceptions by View",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(django_http_exceptions_total_by_view_total{job=\"django\"}[5m])) by (view)",
          "refId": "A",
          "legendFormat": "{{view}}"
        }
      ]
    }
  ]
}
